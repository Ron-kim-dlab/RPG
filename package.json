{
  "name": "rpg-rebuild-workspace",
  "version": "2.0.0",
  "private": true,
  "description": "2D browser RPG monorepo with multiplayer-ready services",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev:web": "corepack pnpm --filter @rpg/web dev",
    "dev:server": "corepack pnpm --filter @rpg/server dev",
    "build": "corepack pnpm -r build",
    "lint": "corepack pnpm -r lint",
    "typecheck": "corepack pnpm -r typecheck",
    "test": "corepack pnpm -r test",
    "test:e2e": "playwright test",
    "security:generate-jwt": "node scripts/security/generate-jwt-secret.mjs",
    "security:create-mongo-user": "node scripts/security/create-mongo-app-user.mjs",
    "security:build-mongo-uri": "node scripts/security/build-mongo-connection-uri.mjs",
    "security:sync-gh-secrets": "node scripts/security/sync-github-secrets.mjs",
    "security:audit-legacy-runtime": "node scripts/security/audit-legacy-runtime.mjs",
    "security:smoke": "corepack pnpm --filter @rpg/server smoke:secrets",
    "legacy:start": "node server.js",
    "legacy:dev": "nodemon server.js",
    "github:labels": "node scripts/sync-github-labels.mjs",
    "github:ruleset": "node scripts/apply-github-ruleset.mjs"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "mongoose": "^6.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.52.0",
    "globals": "^16.2.0",
    "nodemon": "^2.0.22",
    "typescript-eslint": "^8.33.1"
  }
}
