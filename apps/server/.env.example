NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# Generate with: corepack pnpm security:generate-jwt
JWT_SECRET=replace-with-a-32-character-minimum-secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10
STORAGE_DRIVER=mongo
# Use a dedicated MongoDB user for shared or deployed environments.
MONGODB_URI=mongodb://localhost:27017/rpg-rebuild
